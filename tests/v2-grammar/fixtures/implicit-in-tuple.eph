// Implicit-`in` with tuple binders. Two `let` statements destructuring
// pairs, followed by a final expression. This is the shape bridge.eph
// uses on its TEA loop.

module hyperpolymath/ephapax/test

fn entry(): I32 =
  let p: (I32, I32) = (1, 2)
  let (a, b) = p
  let q: (I32, I32) = (a, b)
  let (c, d) = q
  c
