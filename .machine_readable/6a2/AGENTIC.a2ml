# SPDX-License-Identifier: PMPL-1.0-or-later
# AGENTIC.a2ml - AI agent interaction patterns for ephapax
# Template from: https://github.com/hyperpolymath/standards

# ── Agent Configuration ────────────────────────────────────────────────────
[agentic-config]
version = "1.0.0"
project = "ephapax"

# ── Claude Code Settings ──────────────────────────────────────────────────
[agentic-config.claude-code]
model = "claude-opus-4-5-20251101"
tools = ["read", "edit", "bash", "grep", "glob"]
permissions = "read-all"

# ── Coding Patterns ───────────────────────────────────────────────────────
[agentic-config.patterns]
code-review = "thorough"
refactoring = "conservative"
testing = "comprehensive"
documentation = "inline"

# ── Language Constraints ──────────────────────────────────────────────────
[agentic-config.constraints]
# Allowed languages for the project
languages = ["rust", "zig", "idris2", "coq", "bash", "just"]
# Organization-wide banned languages
banned = ["typescript", "go", "python", "makefile"]

# ── Project-Specific Overrides ────────────────────────────────────────────
[agentic-config.project-specific]
# NEVER modify formal proofs (Coq/Idris2) without verifying them.
# Always run `just golden` before committing to ensure proof closure.
# Respect the dyadic boundary: affine vs linear must be explicitly handled.
last-modified-at = "2026-05-26T21:30:00Z"
modification-summary = "Disambiguation blocks: (a) Ephapax-vs-AffineScript (PR #152 / docs/disambig-ephapax-vs-affinescript); (b) four-layer-typing-redesign naming (PR #154 / docs/four-layer-redesign)"

# ── Disambiguation: Ephapax vs AffineScript ───────────────────────────────
# AI agents have repeatedly conflated this repo (Ephapax) with the unrelated
# language AffineScript (hyperpolymath/affinescript). The two share exactly
# one thing — both target hyperpolymath/typed-wasm — and otherwise have
# different ASTs, type checkers, compilers, and proof stories. The shared
# `affine` syllable names a substructural-logic property in BOTH cases (it's
# a logic-family name), not a project relationship.
[agentic-config.disambiguation]
this = "hyperpolymath/ephapax"
canonical-name = "Ephapax"
distinct-from = ["hyperpolymath/affinescript"]
shared-with-distinct = ["hyperpolymath/typed-wasm"]
internal-sublanguages = ["ephapax-linear", "ephapax-affine"]
# `ephapax-affine` is an internal sublanguage of THIS repo (dyadic with
# ephapax-linear, one AST, one Rust crate). It is NOT the AffineScript
# language at hyperpolymath/affinescript.
ephapax-affine-is-not-affinescript = true
canonical-doc = "https://github.com/hyperpolymath/nextgen-languages/blob/main/docs/disambiguation/ephapax-vs-affinescript.md"
canonical-memory-entry = "feedback_affinescript_ephapax_siblings_not_impl_proof.md"
do-not-apply-cross-repo-lessons-without-explicit-check = true

# ── Disambiguation: Four-Layer Naming ─────────────────────────────────────
# The names "L1/L2/L3/L4", "ephapax-linear/ephapax-affine", and
# "Linear/Affine" (as it appears in echo-types) deliberately overlap because
# the underlying thin-poset construction is the same. Agents MUST
# disambiguate by context (which LAYER the question touches).
[agentic-config.disambiguation.four-layer-names]
L1 = "Layer 1 — region capabilities (explicit live-region threading)"
L2 = "Layer 2 — structural modality (Linear / Affine as admissible-derivation regimes)"
L3 = "Layer 3 — echo residue (irreversibility-residue decoration; planned; recipe from echo-types)"
L4 = "Layer 4 — dyadic mode (project-level mode declaration; planned)"
ephapax-linear = "the Rust crate name (historical); implements BOTH L2 modalities, not just Linear"
ephapax-affine = "informal label for the L2-Affine modality; NOT a separate crate"
echo-types-Linear-Affine = "the L3 modes in echo-types; same names, different layer — these are the irreversibility-residue regimes, not L2 structural modalities"
note = "When in doubt, ask which layer the question touches: L1 (regions), L2 (consumption/weakening), L3 (residue), or L4 (project-level mode). The names overlap because the underlying thin-poset construction is shared; the layers themselves are orthogonal."
reference = "formal/PRESERVATION-DESIGN.md §12.8 (four-layer table)"
