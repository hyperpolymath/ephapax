;; Helper functions
(define (get-completion-percentage)
  "Returns overall project completion as percentage"
  15)

(define (get-blockers priority)
  "Returns list of blockers by priority (critical/high/medium/low)"
  (case priority
    ((critical) '())
    ((high) '("unpinned-actions"))
    ((medium) '("no-branch-protection"))
    ((low) '("benchmark-warnings"))))

(define (get-milestone name)
  "Returns milestone by name"
  (case name
    (("MVP Complete") '(status complete completion 100))
    (("Security & Quality") '(status in-progress completion 40))
    (("Expansion") '(status pending completion 0))))
